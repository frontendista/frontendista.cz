{
	"name": "frontendista.cz",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"package": "vite package",
		"preview": "vite preview",
		"preview:host": "vite preview --host",
		"build:preview:host": "vite build && vite preview --host",
		"prepare": "svelte-kit sync",
		"test:e2e": "playwright test --browser chromium --headed",
		"test:e2e:ci": "playwright test --browser all",
		"test:unit": "vitest",
		"test:unit:watch": "vitest --watch",
		"test:unit:ui": "vitest --ui",
		"test:unit:coverage": "vitest --coverage",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint --ignore-path .gitignore ."
	},
	"dependencies": {
		"@portabletext/svelte": "^1.0.1",
		"@rgossiaux/svelte-headlessui": "^1.0.2",
		"@sanity/client": "^3.3.1",
		"@sveltejs/adapter-vercel": "1.0.0-next.62",
		"@sveltejs/kit": "1.0.0-next.377",
		"clsx": "^1.2.1",
		"nanopop": "^2.1.0",
		"svelte": "^3.49.0",
		"svelte-forms-lib": "^2.0.1",
		"tinydate": "^1.3.0",
		"zod": "^3.17.3"
	},
	"devDependencies": {
		"@playwright/test": "1.22.2",
		"@sveltejs/vite-plugin-svelte": "^1.0.1",
		"@testing-library/jest-dom": "^5.16.4",
		"@testing-library/svelte": "^3.1.1",
		"@types/html-minifier-terser": "^6.1.0",
		"@types/node": "^18.0.0",
		"@types/testing-library__jest-dom": "^5.14.3",
		"@types/ua-parser-js": "^0.7.36",
		"@typescript-eslint/eslint-plugin": "^5.10.1",
		"@typescript-eslint/parser": "^5.10.1",
		"@vanilla-extract/css": "^1.7.2",
		"@vanilla-extract/css-utils": "^0.1.2",
		"@vanilla-extract/recipes": "^0.2.5",
		"@vanilla-extract/sprinkles": "^1.4.1",
		"@vanilla-extract/vite-plugin": "^3.2.1",
		"@vitest/ui": "^0.10.5",
		"autoprefixer": "^10.4.5",
		"c8": "^7.11.2",
		"cssnano": "^5.1.7",
		"dotenv": "^16.0.1",
		"eslint": "^7.32.0",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-svelte3": "^3.4.1",
		"happy-dom": "^3.1.1",
		"html-minifier-terser": "7.0.0-beta.0",
		"postcss": "^8.4.12",
		"svelte-check": "^2.2.6",
		"svelte-preprocess": "^4.10.1",
		"tslib": "^2.3.1",
		"typescript": "~4.6.2",
		"ua-parser-js": "^1.0.2",
		"vercel": "^24.2.5",
		"vite": "^3.0.0",
		"vite-plugin-svelte-svg": "^2.0.1",
		"vitest": "^0.10.5"
	},
	"type": "module"
}
