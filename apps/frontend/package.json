{
	"name": "frontendista.cz",
	"version": "0.0.1",
	"scripts": {
		"dev": "svelte-kit dev",
		"build": "svelte-kit build",
		"package": "svelte-kit package",
		"preview": "svelte-kit preview",
		"prepare": "svelte-kit sync",
		"test:e2e": "playwright test --quiet",
		"test:unit": "vitest",
		"test:unit:watch": "vitest --watch",
		"test:unit:ui": "vitest --ui",
		"test:unit:coverage": "vitest --coverage",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint --ignore-path .gitignore ."
	},
	"dependencies": {
		"@portabletext/svelte": "^1.0.1",
		"@sanity/client": "^3.3.1",
		"@sveltejs/adapter-vercel": "^1.0.0-next.50",
		"@sveltejs/kit": "next",
		"svelte": "^3.44.0",
		"zod": "^3.17.3"
	},
	"devDependencies": {
		"@playwright/test": "1.22.2",
		"@poppanator/sveltekit-svg": "^0.3.4",
		"@sveltejs/vite-plugin-svelte": "^1.0.0-next.42",
		"@testing-library/jest-dom": "^5.16.4",
		"@testing-library/svelte": "^3.1.1",
		"@types/html-minifier-terser": "^6.1.0",
		"@types/testing-library__jest-dom": "^5.14.3",
		"@typescript-eslint/eslint-plugin": "^5.10.1",
		"@typescript-eslint/parser": "^5.10.1",
		"@vanilla-extract/css": "^1.7.2",
		"@vanilla-extract/css-utils": "^0.1.2",
		"@vanilla-extract/vite-plugin": "^3.2.1",
		"@vitest/ui": "^0.10.5",
		"autoprefixer": "^10.4.5",
		"c8": "^7.11.2",
		"cssnano": "^5.1.7",
		"dotenv": "^16.0.1",
		"eslint": "^7.32.0",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-svelte3": "^3.2.1",
		"happy-dom": "^3.1.1",
		"html-minifier-terser": "^7.0.0-alpha.2",
		"postcss": "^8.4.12",
		"svelte-check": "^2.2.6",
		"svelte-preprocess": "^4.10.1",
		"tslib": "^2.3.1",
		"typescript": "~4.6.2",
		"vercel": "^24.2.5",
